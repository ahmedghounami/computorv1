#!/usr/bin/env python3
import sys

EPSILON = 0.000000001 


def absolute(value):
    if value < 0:
        return -value
    return value


def is_zero(value):
    return absolute(value) < EPSILON


def square_root(number):
    if number < 0:
        raise ValueError("Cannot calculate the square root of a negative number")

    if number == 0:
        return 0.0

    if number >= 1:
        guess = number
    else:
        guess = 1.0

    while True:
        next_guess = (guess + number / guess) / 2

        if absolute(next_guess - guess) < EPSILON:
            return next_guess

        guess = next_guess


def is_valid_term(term):
    term = term.strip().replace(" ", "")

    if term == "":
        return False

    if term.count("*") > 1:
        return False

    try:
        parse_term(term)
        return True
    except (ValueError, TypeError):
        return False


def parse_term(term):
    term = term.strip().replace(" ", "")
    
    term_upper = term.upper()

    if "X" not in term_upper:
        coef = float(term)
        power = 0
        return power, coef

    if term_upper.count("X") != 1:
        raise ValueError("Invalid term")

    before_x, after_x = term_upper.split("X")

    if before_x == "":
        coef = 1.0
    elif before_x == "+":
        coef = 1.0
    elif before_x == "-":
        coef = -1.0
    else:
        if before_x.endswith("*"):
            before_x = before_x[:-1]

        coef = float(before_x)

    if after_x == "":
        power = 1
    else:
        if not after_x.startswith("^"):
            raise ValueError("Invalid term")

        power_text = after_x[1:]

        if power_text == "":
            raise ValueError("Invalid power")

        power = int(power_text)

        if power < 0:
            raise ValueError("Negative power")

    return power, coef


def parse_side(side):
    poly = {}

    side = side.replace("-", "+-")
    terms = side.split("+")

    for term in terms:
        term = term.strip()

        if term == "":
            continue

        if not is_valid_term(term):
            print(f"Syntax error: '{term}'")
            exit(1)

        power, coef = parse_term(term)
        poly[power] = poly.get(power, 0) + coef

    return poly


def reduce_equation(left_poly, right_poly):
    reduced = {}

    for power in left_poly:
        reduced[power] = left_poly[power]

    for power in right_poly:
        if power in reduced:
            reduced[power] = reduced[power] - right_poly[power]
        else:
            reduced[power] = -right_poly[power]

    return reduced


def get_degree(poly):
    degree = 0

    for power in poly:
        coef = poly[power]

        if not is_zero(coef) and power > degree:
            degree = power

    return degree


def format_number(number):
    if is_zero(number):
        return 0

    if number == int(number):
        return int(number)

    return f"{number:.6f}".rstrip("0").rstrip(".")


def print_reduced_form(poly):
    mathematical_expression = ""

    for power in sorted(poly.keys()):
        coef = poly[power]

        if is_zero(coef):
            continue
        elif mathematical_expression == "":
            mathematical_expression += f"{format_number(coef)} * X^{power}"
        elif coef > 0:
            mathematical_expression += f" + {format_number(coef)} * X^{power}"
        else:
            mathematical_expression += f" - {format_number(absolute(coef))} * X^{power}"

    if mathematical_expression == "":
        mathematical_expression = "0 * X^0"

    print(f"Reduced form: {mathematical_expression} = 0")


def solve_degree_0(poly):
    c = poly.get(0, 0)

    if is_zero(c):
        print("Any real number is a solution.")
    else:
        print("No solution.")


def solve_degree_1(poly):
    c = poly.get(0, 0)
    b = poly.get(1, 0)

    print(f"Coefficients: b = {format_number(b)}, c = {format_number(c)}")
    print(f"Using formula: x = -c/b")
    
    solution = -c / b
    
    print(f"x = -{format_number(c)}/{format_number(b)} = {format_number(solution)}")
    print("\nThe solution is:")
    print(format_number(solution))


def solve_degree_2(poly):
    a = poly.get(2, 0)
    b = poly.get(1, 0)
    c = poly.get(0, 0)

    print(f"Coefficients: a = {format_number(a)}, b = {format_number(b)}, c = {format_number(c)}")
    print(f"Discriminant: Δ = b² - 4ac = {format_number(b * b)} - {format_number(4 * a * c)} = {format_number(b * b - 4 * a * c)}")
    
    discriminant = b * b - 4 * a * c

    if discriminant > EPSILON:
        discriminant_root = square_root(discriminant)
        print(f"√Δ = {format_number(discriminant_root)}")
        
        print("\nUsing quadratic formula: x = (-b ± √Δ) / 2a")
        print(f"x₁ = (-({format_number(b)}) - {format_number(discriminant_root)}) / (2 × {format_number(a)})")
        root1 = (-b - discriminant_root) / (2 * a)
        print(f"x₁ = {format_number(-b - discriminant_root)} / {format_number(2 * a)} = {format_number(root1)}")
        
        print(f"\nx₂ = (-({format_number(b)}) + {format_number(discriminant_root)}) / (2 × {format_number(a)})")
        root2 = (-b + discriminant_root) / (2 * a)
        print(f"x₂ = {format_number(-b + discriminant_root)} / {format_number(2 * a)} = {format_number(root2)}")

        print("\nDiscriminant is strictly positive, the two solutions are:")
        print(format_number(root1))
        print(format_number(root2))

    elif discriminant < -EPSILON:
        print("Discriminant is strictly negative, the two complex solutions are:")
        discriminant_abs_root = square_root(-discriminant)
        print(f"√|Δ| = {format_number(discriminant_abs_root)}")
        
        print("\nUsing quadratic formula: x = (-b ± i√|Δ|) / 2a")
        
        real_part = -b / (2 * a)
        imaginary_part = (
            discriminant_abs_root
            / absolute(2 * a)
        )
        
        print(f"x₁ = (-({format_number(b)}) - i×{format_number(discriminant_abs_root)}) / (2 × {format_number(a)})")
        print(f"x₁ = {format_number(real_part)} - {format_number(imaginary_part)}i")
        
        print(f"\nx₂ = (-({format_number(b)}) + i×{format_number(discriminant_abs_root)}) / (2 × {format_number(a)})")
        print(f"x₂ = {format_number(real_part)} + {format_number(imaginary_part)}i")
        
        print(f"\n{format_number(real_part)} + {format_number(imaginary_part)}i")
        print(f"{format_number(real_part)} - {format_number(imaginary_part)}i")

    else:
        root = -b / (2 * a)
        print("Discriminant is zero, the solution is:")
        print(format_number(root))


def main():
    equation = ""

    if len(sys.argv) == 2:
        equation = sys.argv[1]
    elif len(sys.argv) < 2:
        equation = input("Enter an equation: ")
    elif len(sys.argv) > 2:
        print('Usage: python computor.py "equation"')
        return

    if equation.count("=") != 1:
        print("Syntax error: equation must contain exactly one '='")
        return

    left, right = equation.split("=")

    if left.strip() == "" or right.strip() == "":
        print("Syntax error: empty side")
        return

    left_poly = parse_side(left)
    right_poly = parse_side(right)

    reduced = reduce_equation(left_poly, right_poly)
    print_reduced_form(reduced)

    degree = get_degree(reduced)

    print(f"Polynomial degree: {degree}")

    if degree == 0:
        solve_degree_0(reduced)
    elif degree == 1:
        solve_degree_1(reduced)
    elif degree == 2:
        solve_degree_2(reduced)
    else:
        print("The polynomial degree is strictly greater than 2, I can't solve.")


if __name__ == "__main__":
    main()